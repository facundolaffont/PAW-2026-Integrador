<!DOCTYPE html>
<html lang="es">
  <%- include('partials/head.ejs') %>
  <body>
    <script>
      if (!getCookie('nombreUsuario')) window.location.href = '/public/bienvenida';
    </script>
    <%- include('partials/navbar.ejs') %>
    <div class="container-inicio">
      <img src="/images/uno-logo.png" alt="UNO" class="logo-inicio" />
      <div class="botones-inicio">
        <button class="btn-inicio" onclick="window.location.href = '/public/jugar'">JUGAR</button>
        <button class="btn-inicio" onclick="window.location.href = '/public/puntajes'">
          RANKING
        </button>
        <button class="btn-inicio" onclick="window.location.href = '/public/reglas'">
          REGLAS
        </button>
        <button class="btn-inicio" onclick="salir()">SALIR</button>
      </div>
    </div>
    <script>
      async function salir() {
        try {
          await fetch('/api/salir', { method: 'POST' });
        } catch (_) {}
        window.location.href = '/public/bienvenida';
      }
    </script>
  </body>
</html>
