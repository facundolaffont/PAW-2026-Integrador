<!DOCTYPE html>
<html lang="es">
  <%- include('partials/head.ejs') %>
  <body>
    <nav class="navbar">
      <div class="navbar-logo">UNO Argentino</div>
      <div class="navbar-info" id="estado-partida">Conectando...</div>
      <div class="navbar-links">
        <a href="#" id="salir" class="navbar-link">Salir</a>
      </div>
    </nav>

    <div class="lobby">
      <div class="lobby-principal">
        <h1 id="lobby-titulo">Sala</h1>
        <p id="lobby-info" class="lobby-info"></p>

        <h2 class="lobby-subtitulo">Jugadores</h2>
        <ul id="lista-jugadores" class="lista-jugadores"></ul>

        <button id="btn-iniciar" class="btn-iniciar" hidden>INICIAR PARTIDA</button>
      </div>

      <div class="lobby-bitacora">
        <h2 class="lobby-subtitulo">Actividad</h2>
        <ul id="lista-mensajes" class="lista-mensajes"></ul>
      </div>
    </div>

    <script>
      (function () {
        const jugadorId = sessionStorage.getItem('jugadorId');
        if (!jugadorId) window.location.href = '/public/bienvenida';
      })();

      const jugadorId = sessionStorage.getItem('jugadorId');
      const partidaId = new URLSearchParams(window.location.search).get('partidaId');

      const elEstado = document.getElementById('estado-partida');
      const elTitulo = document.getElementById('lobby-titulo');
      const elInfo = document.getElementById('lobby-info');
      const elLista = document.getElementById('lista-jugadores');
      const elListaMensajes = document.getElementById('lista-mensajes');
      const btnIniciar = document.getElementById('btn-iniciar');

      let esCreador = false;
      let maxJugadores = null;
      let ws;

      function mostrarMensaje(texto, tipo = 'info') {
        const li = document.createElement('li');
        li.className = 'mensaje-item';
        li.dataset.tipo = tipo;

        const ahora = new Date();
        const hora = ahora.toLocaleString('es-AR', {
          day: '2-digit',
          month: '2-digit',
          year: 'numeric',
          hour: '2-digit',
          minute: '2-digit',
          second: '2-digit',
        });
        li.innerHTML = `<span class="mensaje-hora">${hora}</span> ${texto}`;

        elListaMensajes.appendChild(li);
        elListaMensajes.scrollTop = elListaMensajes.scrollHeight;
      }

      function pintarJugadores(jugadores) {
        elLista.innerHTML = jugadores
          .map((nombre) => `<li class="jugador-item">${nombre}</li>`)
          .join('');
        const cant = jugadores.length;
        const total = maxJugadores != null ? `/${maxJugadores}` : '';
        elInfo.textContent = `${cant}${total} jugadores en la sala`;
      }

      async function cargarResumen() {
        if (!partidaId) {
          mostrarMensaje('Falta el ID de partida.', 'error');
          return;
        }

        try {
          const response = await fetch(`/api/partidas/${encodeURIComponent(partidaId)}`);
          if (!response.ok) {
            const data = await response.json().catch(() => ({}));
            mostrarMensaje(data.error || 'No se pudo cargar la partida.', 'error');
            return;
          }
          const sala = await response.json();
          esCreador = sala.creadorId === jugadorId;
          maxJugadores = sala.maxJugadores;
          elTitulo.textContent = `Sala de ${sala.jugadores[0] || 'jugador'}`;
          pintarJugadores(sala.jugadores);
          if (esCreador) btnIniciar.hidden = false;
        } catch (err) {
          console.error(err);
          mostrarMensaje('Error de red al cargar la partida.', 'error');
        }
      }

      function conectarWS() {
        const proto = window.location.protocol === 'https:' ? 'wss:' : 'ws:';
        const url = `${proto}//${window.location.host}/ws?jugadorId=${encodeURIComponent(jugadorId)}&partidaId=${encodeURIComponent(partidaId)}`;
        ws = new WebSocket(url);

        ws.addEventListener('open', () => {
          elEstado.textContent = 'En sala';
        });

        ws.addEventListener('message', (e) => {
          let msg;
          try {
            msg = JSON.parse(e.data);
          } catch {
            return;
          }
          manejarEvento(msg);
        });

        ws.addEventListener('close', () => {
          elEstado.textContent = 'Desconectado';
        });

        ws.addEventListener('error', (err) => {
          console.error('WS error', err);
          elEstado.textContent = 'Error de conexión';
        });
      }

      function manejarEvento(msg) {
        const { evento, ...datos } = msg;
        switch (evento) {
          case 'estado-partida': {
            const estado = datos.estado;
            if (estado.estado === 'jugando') {
              elEstado.textContent = 'Partida en curso';
              btnIniciar.hidden = true;
              mostrarMensaje('La partida ya empezó.');
            }
            const nombres = (estado.jugadores || []).map((j) => j.nombreUsuario);
            pintarJugadores(nombres);
            break;
          }
          case 'jugador-unido': {
            mostrarMensaje(`${datos.nombreUsuario || 'Un jugador'} ingresó a la sala.`);
            cargarResumen();
            break;
          }
          case 'jugador-salio': {
            mostrarMensaje(`${datos.nombreUsuario || 'Un jugador'} salió de la sala.`);
            cargarResumen();
            break;
          }
          case 'turno-cambiado': {
            elEstado.textContent = 'Partida en curso';
            btnIniciar.hidden = true;
            break;
          }
          case 'error': {
            mostrarMensaje(datos.mensaje || 'Error', 'error');
            break;
          }
          case 'jugador-abandono': {
            mostrarMensaje(datos.mensaje || 'Un jugador abandonó.', 'error');
            break;
          }
        }
      }

      btnIniciar.addEventListener('click', () => {
        if (!ws || ws.readyState !== WebSocket.OPEN) return;
        ws.send(JSON.stringify({ accion: 'iniciar-partida' }));
      });

      document.getElementById('salir').addEventListener('click', (e) => {
        e.preventDefault();
        if (ws) ws.close();
        window.location.href = '/public/';
      });

      cargarResumen();
      conectarWS();
    </script>
  </body>
</html>
