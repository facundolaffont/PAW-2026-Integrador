<!DOCTYPE html>
<html lang="es">
  <%- include('partials/head.ejs') %>
  <body>
    <div class="container-auth">
      <img src="/images/uno-logo.png" alt="UNO" class="logo-auth" />
      <form class="auth-form" onsubmit="ingresar(event)">
        <h1 class="auth-title">Ingresar</h1>

        <label for="nombreUsuario">Nombre de usuario</label>
        <input
          type="text"
          id="nombreUsuario"
          name="nombreUsuario"
          required
          autofocus
          autocomplete="username"
          maxlength="50"
        />

        <label for="password">Contraseña</label>
        <div class="input-password-wrapper">
          <input
            type="password"
            id="password"
            name="password"
            required
            autocomplete="current-password"
          />
          <button
            type="button"
            class="btn-toggle-password"
            onclick="togglePassword('password', this)"
            tabindex="-1"
            aria-label="Mostrar contraseña"
          >
            👁
          </button>
        </div>

        <p class="auth-error" id="error" hidden></p>
        <button type="submit" id="btn-submit" class="btn-auth">INGRESAR</button>
        <a href="/public/registrarse" class="auth-link">¿No tenés cuenta? Registrate</a>
        <a href="/public/bienvenida" class="btn-auth btn-auth-secundario"
          >VOLVER AL MENÚ PRINCIPAL</a
        >
      </form>
    </div>
  </body>
  <script>
    fetch('/api/me').then((r) => {
      if (r.ok) window.location.replace('/public/');
    });

    function togglePassword(inputId, btn) {
      const input = document.getElementById(inputId);
      if (input.type === 'password') {
        input.type = 'text';
        btn.textContent = '🙈';
      } else {
        input.type = 'password';
        btn.textContent = '👁';
      }
    }

    async function ingresar(e) {
      e.preventDefault();
      const error = document.getElementById('error');
      const btn = document.getElementById('btn-submit');
      error.hidden = true;

      const nombreUsuario = e.target.nombreUsuario.value.trim();
      const password = e.target.password.value;

      btn.disabled = true;
      btn.textContent = 'Ingresando...';

      try {
        const response = await fetch('/api/ingresar', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ nombreUsuario, password }),
        });

        const data = await response.json();

        if (!response.ok) {
          error.textContent = data.error || 'Error al ingresar.';
          error.hidden = false;
          return;
        }

        window.location.href = '/public/';
      } catch (err) {
        console.error(err);
        error.textContent = 'Error de red o del servidor.';
        error.hidden = false;
      } finally {
        btn.disabled = false;
        btn.textContent = 'INGRESAR';
      }
    }
  </script>
</html>
