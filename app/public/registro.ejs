<!DOCTYPE html>
<html lang="es">
  <%- include('partials/head.ejs') %>
  <body>
    <div class="container-auth">
      <img src="/images/uno-logo.png" alt="UNO" class="logo-auth" />
      <form class="auth-form" onsubmit="registrar(event)">
        <h1 class="auth-title">Crear cuenta</h1>

        <label for="nombreUsuario">Nombre de usuario</label>
        <input
          type="text"
          id="nombreUsuario"
          name="nombreUsuario"
          required
          autofocus
          autocomplete="username"
          maxlength="50"
        />
        <p class="auth-hint">3–50 caracteres. Solo letras, números, _ o -</p>

        <label for="password">Contraseña</label>
        <div class="input-password-wrapper">
          <input
            type="password"
            id="password"
            name="password"
            required
            autocomplete="new-password"
          />
          <button type="button" class="btn-toggle-password" onclick="togglePassword('password', this)" tabindex="-1" aria-label="Mostrar contraseña">👁</button>
        </div>
        <p class="auth-hint">Mínimo 4 caracteres</p>

        <label for="passwordConfirm">Repetir contraseña</label>
        <div class="input-password-wrapper">
          <input
            type="password"
            id="passwordConfirm"
            name="passwordConfirm"
            required
            autocomplete="new-password"
          />
          <button type="button" class="btn-toggle-password" onclick="togglePassword('passwordConfirm', this)" tabindex="-1" aria-label="Mostrar contraseña">👁</button>
        </div>

        <p class="auth-error" id="error" hidden></p>
        <button type="submit" id="btn-submit" class="btn-auth">REGISTRARSE</button>
        <a href="/public/ingresar" class="auth-link">¿Ya tenés cuenta? Ingresá</a>
      </form>
    </div>
  </body>
  <script>
    if (getCookie('nombreUsuario')) {
      window.location.replace('/public/');
    }

    function togglePassword(inputId, btn) {
      const input = document.getElementById(inputId);
      if (input.type === 'password') {
        input.type = 'text';
        btn.textContent = '🙈';
      } else {
        input.type = 'password';
        btn.textContent = '👁';
      }
    }

    async function registrar(e) {
      e.preventDefault();
      const error = document.getElementById('error');
      const btn = document.getElementById('btn-submit');
      error.hidden = true;

      const nombreUsuario = e.target.nombreUsuario.value.trim();
      const password = e.target.password.value;
      const passwordConfirm = e.target.passwordConfirm.value;

      // Validaciones del lado del cliente
      const NOMBRE_REGEX = /^[a-zA-Z0-9_\-áéíóúñüÁÉÍÓÚÑÜ]{3,50}$/;
      if (!NOMBRE_REGEX.test(nombreUsuario)) {
        error.textContent = 'El nombre debe tener entre 3 y 50 caracteres (letras, números, _ o -).';
        error.hidden = false;
        return;
      }

      if (password.length < 4) {
        error.textContent = 'La contraseña debe tener al menos 4 caracteres.';
        error.hidden = false;
        return;
      }

      if (password !== passwordConfirm) {
        error.textContent = 'Las contraseñas no coinciden.';
        error.hidden = false;
        return;
      }

      btn.disabled = true;
      btn.textContent = 'Registrando...';

      try {
        const response = await fetch('/api/registrarse', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ nombreUsuario, password }),
        });

        const data = await response.json();

        if (!response.ok) {
          error.textContent =
            response.status === 409
              ? 'Ese nombre de usuario ya está en uso.'
              : data.error || 'Error al registrarse.';
          error.hidden = false;
          return;
        }

        window.location.href = '/public/';
      } catch (err) {
        console.error(err);
        error.textContent = 'Error de red o del servidor.';
        error.hidden = false;
      } finally {
        btn.disabled = false;
        btn.textContent = 'REGISTRARSE';
      }
    }
  </script>
</html>
