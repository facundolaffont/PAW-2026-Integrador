<!DOCTYPE html>
<html lang="es">
  <%- include('partials/head.ejs') %>
  <body>
    <div class="container-crear-sala">
      <div class="form-crear-sala">
        <h1>Crear nueva sala</h1>

        <form onsubmit="enviarCrearSala(event)">
          <label for="num-jugadores">Cantidad máxima de jugadores</label>
          <input
            type="number"
            id="num-jugadores"
            name="num_jugadores"
            class="input-crear"
            min="2"
            max="4"
            value="4"
            required
          />

          <label for="cantidad-bots">Cantidad de bots <span class="hint" id="hint-bots"></span></label>
          <input
            type="number"
            id="cantidad-bots"
            name="cantidad_bots"
            class="input-crear"
            min="0"
            max="3"
            value="0"
            required
          />

          <p class="error-crear" id="error" hidden></p>

          <div class="botones-crear">
            <button type="button" class="btn-crear" onclick="window.location.href = '/public/jugar'">
              CANCELAR
            </button>
            <button type="submit" class="btn-crear">CREAR PARTIDA</button>
          </div>
        </form>
      </div>
    </div>
    <script>
      (function () {
        const jugadorId = sessionStorage.getItem('jugadorId');
        if (!jugadorId) window.location.href = '/public/bienvenida';
      })();

      // Mantiene el máximo de bots = maxJugadores - 1 (siempre te queda lugar a vos).
      // Si el valor actual de bots supera el nuevo máximo, lo recorta.
      const inputJugadores = document.getElementById('num-jugadores');
      const inputBots = document.getElementById('cantidad-bots');
      const hintBots = document.getElementById('hint-bots');

      function sincronizarLimiteBots() {
        const max = Math.max(1, parseInt(inputJugadores.value, 10) || 2) - 1;
        inputBots.max = String(max);
        hintBots.textContent = `(máx. ${max})`;
        if (parseInt(inputBots.value, 10) > max) inputBots.value = max;
      }

      inputJugadores.addEventListener('input', sincronizarLimiteBots);
      inputBots.addEventListener('input', () => {
        const max = parseInt(inputBots.max, 10);
        if (parseInt(inputBots.value, 10) > max) inputBots.value = max;
      });
      sincronizarLimiteBots();

      async function enviarCrearSala(e) {
        e.preventDefault();
        const error = document.getElementById('error');
        error.hidden = true;

        const jugadorId = sessionStorage.getItem('jugadorId');
        const maxJugadores = parseInt(e.target.num_jugadores.value, 10);
        const cantidadBots = parseInt(e.target.cantidad_bots.value, 10);

        if (1 + cantidadBots > maxJugadores) {
          error.textContent = 'La cantidad de bots no puede dejar la sala llena (debe quedar lugar para vos).';
          error.hidden = false;
          return;
        }

        try {
          const response = await fetch('/api/partidas', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ jugadorId, maxJugadores, cantidadBots }),
          });
          const data = await response.json();

          if (!response.ok) {
            error.textContent = data.error || 'Error al crear la sala.';
            error.hidden = false;
            return;
          }

          window.location.href = `/public/partida?partidaId=${encodeURIComponent(data.partidaId)}`;
        } catch (err) {
          console.error(err);
          error.textContent = 'Error de red o del servidor.';
          error.hidden = false;
        }
      }
    </script>
  </body>
</html>
