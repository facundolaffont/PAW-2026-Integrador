<!DOCTYPE html>
<html lang="es">
  <%- include('partials/head.ejs') %>
  <body>
    <%- include('partials/navbar.ejs') %>
    <%
      const _puntajes = Array.isArray(puntajes) ? puntajes : [];
    %>
    <div class="container-puntajes">
      <div class="puntajes-box">
        <img src="/images/uno-logo.png" alt="UNO" class="logo-puntajes" />
        <h1>Ranking global</h1>
        <div class="tabla-puntajes">
          <table>
            <thead>
              <tr>
                <th>#</th>
                <th>Jugador</th>
                <th>Puntaje</th>
              </tr>
            </thead>
            <tbody>
              <% if (_puntajes.length === 0) { %>
                <tr>
                  <td colspan="3" class="vacio-puntajes">Todavía no hay puntajes registrados.</td>
                </tr>
              <% } else { %>
                <% _puntajes.forEach(function(p, i) { %>
                  <%
                    const medalla = i === 0 ? '🥇' : i === 1 ? '🥈' : i === 2 ? '🥉' : i + 1;
                  %>
                  <tr data-jugador-id="<%= p.jugadorId %>">
                    <td class="puesto"><%= medalla %></td>
                    <td><%= p.nombreUsuario %></td>
                    <td class="puntaje-valor"><%= p.puntajeGlobal %></td>
                  </tr>
                <% }); %>
              <% } %>
            </tbody>
          </table>
        </div>
        <button class="btn-puntajes" onclick="window.location.href='/public/'">VOLVER</button>
      </div>
    </div>

    <!-- Schema.org: ItemList (ranking de jugadores) -->
    <% if (_puntajes.length > 0) { %>
    <script type="application/ld+json">
    <%- JSON.stringify({
      "@context": "https://schema.org",
      "@type": "ItemList",
      "name": "Ranking Global — UNO Argentino",
      "description": "Los mejores jugadores de UNO Argentino ordenados por puntaje global.",
      "url": seo.canonicalUrl,
      "numberOfItems": _puntajes.length,
      "itemListOrder": "https://schema.org/ItemListOrderDescending",
      "itemListElement": _puntajes.slice(0, 10).map(function(p, i) {
        return {
          "@type": "ListItem",
          "position": i + 1,
          "name": p.nombreUsuario,
          "description": "Puntaje global: " + p.puntajeGlobal
        };
      })
    }) %>
    </script>
    <% } %>
  </body>
  <script>
    fetch('/api/me').then(r => r.ok ? r.json() : null).then(data => {
      if (!data) return;
      const fila = document.querySelector(`tr[data-jugador-id="${data.jugadorId}"]`);
      if (fila) fila.classList.add('fila-actual');
    });
  </script>
</html>
