<!doctype html>
<html lang="es">
  <%- include('partials/head.ejs') %>
  <body>
    <div class="container-salas">
      <div class="header-salas">
        <img src="/images/uno-logo.png" alt="UNO" class="logo-salas" />
        <h2>Salas disponibles</h2>
      </div>
      <input type="text" class="input-buscar" placeholder="Buscar sala" />
      <div class="tabla-salas">
        <table>
          <thead>
            <tr>
              <th>Nombre</th>
              <th>Jugadores</th>
            </tr>
          </thead>
          <tbody>
            <tr>
              <td>SALA 1</td>
              <td>3/4</td>
            </tr>
            <tr>
              <td>SALA 2</td>
              <td>2/4</td>
            </tr>
            <tr>
              <td>SALA 3</td>
              <td>4/4</td>
            </tr>
            <tr>
              <td>SALA 4</td>
              <td>1/4</td>
            </tr>
          </tbody>
        </table>
      </div>
      <div class="botones-salas">
        <button class="btn-salas">PARTIDA RÁPIDA</button>
        <button class="btn-salas">CREAR PARTIDA</button>
      </div>
    </div>
  </body>
</html>
